{
  "name": "@restart/grid",
  "version": "0.0.1",
  "private": true,
  "description": "Backward-compat re-export of @restart/grid-core (kept while consumers migrate to importing grid-core directly). Part of the Papercusp grid stack.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
