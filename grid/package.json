      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@glideapps/glide-data-grid": "^6.0.3",
    "@restart/grid-core": "*"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@papercusp/test-config": "*",
    "vitest": "^4.1.4"
  }
}
