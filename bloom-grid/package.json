{
  "name": "@restart/bloom-grid",
  "version": "0.0.1",
  "private": true,
  "description": "Bloom-filter-backed grid data layer: a versioned row store, a server-side bloom-query handler, and client React hooks (useBloomQuery / useInfiniteBloomQuery) for incremental sync of large cold catalogs. Part of the Papercusp grid stack.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "bloom-filters": "^3.0.4"
  },
  "devDependencies": {
    "vitest": "^4.1.5",
    "@papercusp/test-config": "*"
  },
  "scripts": {
    "test": "vitest run"
  }
}
